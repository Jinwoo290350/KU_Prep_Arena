# ──────────────────────────────────────────────
#  KU Prep Arena — .gitignore
# ──────────────────────────────────────────────

# ── Next.js ────────────────────────────────────
.next/
out/
build/

# ── Dependencies ───────────────────────────────
node_modules/
.pnpm-store/
.history
# ── Environment & secrets ──────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ── TypeScript build ───────────────────────────
tsconfig.tsbuildinfo
next-env.d.ts

# ── Editor & OS ────────────────────────────────
.DS_Store
Thumbs.db
.history/
.idea/
.vscode/settings.json
*.swp
*.swo

# ── v0 runtime (Vercel dev tool artefacts) ─────
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# ── Python / Jupyter (ai/ section) ─────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/

# ── AI dataset & results (large / generated) ───
ai/dataset/sample_pdfs/*.pdf
ai/dataset/generated/*.json
ai/eval/results/*.json
ai/eval/results/*.html
# ai/dataset/rated/ — tracked intentionally for few-shot prompting

# ── Logs ───────────────────────────────────────
*.log
vllm-*.log
jupyter-*.log
npm-debug.log*
pnpm-debug.log*
.history/
# ── Misc ───────────────────────────────────────
.vercel/
.claude/
coverage/
ai/agents/
